# Firebase Admin SDK Configuration
# Get these values from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key_from_service_account
FIREBASE_CLIENT_EMAIL=your_firebase_client_email_from_service_account

# Client URL for CORS configuration
CLIENT_URL=http://localhost:5173

# Server Port
PORT=3001

# Node Environment
NODE_ENV=development
